{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./node_modules/ultracite/config/oxlint/core/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/react/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/next/.oxlintrc.json"
  ],
  "ignorePatterns": [
    ".agents",
    ".claude",
    ".cursor",
    "**/android",
    "**/ios",
    "**/utils/polyfills.ts"
  ],
  "rules": {
    "no-use-before-define": "allow",
    "oxc/approx-constant": "allow",
    "unicorn/prefer-node-protocol": "allow",
    "func-style": ["error", "declaration", { "allowArrowFunctions": true }],
    "prefer-destructuring": [
      "error",
      {
        "AssignmentExpression": { "array": true, "object": false },
        "VariableDeclarator": { "array": true, "object": true }
      }
    ],
    "typescript/consistent-type-definitions": ["allow", "type"],
    "no-negated-condition": "allow",
    "no-inline-comments": "allow", // Remove it later
    "no-warning-comments": "allow", // Remove it later
    "no-shadow": "allow", // Remove it later

    // Rules with remaining errors - fix over time
    "react-perf/jsx-no-new-function-as-prop": "allow",
    "import/consistent-type-specifier-style": "allow",
    "unicorn/switch-case-braces": "allow",
    "typescript/no-import-type-side-effects": "allow",
    "unicorn/filename-case": "allow",
    "unicorn/numeric-separators-style": "allow",
    "unicorn/prefer-number-properties": "allow",
    "typescript/no-non-null-assertion": "allow",
    "unicorn/prefer-spread": "allow",
    "unicorn/prefer-module": "allow",
    "unicorn/no-nested-ternary": "allow",
    "node/global-require": "allow",
    "unicorn/number-literal-case": "allow",
    "unicorn/prefer-string-replace-all": "allow",
    "react/no-array-index-key": "allow",
    "unicorn/prefer-string-slice": "allow",
    "unicorn/prefer-ternary": "allow",
    "typescript/no-inferrable-types": "allow",
    "unicorn/consistent-function-scoping": "allow",
    "promise/prefer-await-to-then": "allow",
    "promise/avoid-new": "allow",
    "unicorn/no-useless-undefined": "allow",
    "typescript/consistent-type-imports": "allow",
    "typescript/consistent-indexed-object-style": "allow",
    "unicorn/prefer-regexp-test": "allow",
    "unicorn/catch-error-name": "allow",
    "unicorn/no-array-reverse": "allow",
    "react/jsx-handler-names": "allow",
    "import/no-named-as-default": "allow",
    "unicorn/prefer-at": "allow",
    "unicorn/no-useless-fallback-in-spread": "allow",
    "typescript/no-dynamic-delete": "allow",
    "unicorn/no-array-reduce": "allow",
    "react/style-prop-object": "allow",
    "unicorn/no-immediate-mutation": "allow",
    "react/jsx-no-useless-fragment": "allow",
    "unicorn/prefer-code-point": "allow",
    "unicorn/no-zero-fractions": "allow",
    "promise/prefer-await-to-callbacks": "allow",
    "unicorn/prefer-array-some": "allow",
    "unicorn/prefer-array-index-of": "allow",
    "unicorn/no-lonely-if": "allow",
    "unicorn/no-hex-escape": "allow",
    "unicorn/consistent-existence-index-check": "allow",
    "import/no-named-as-default-member": "allow",
    "unicorn/no-useless-spread": "allow",
    "unicorn/no-useless-collection-argument": "allow",
    "promise/param-names": "allow",
    "unicorn/no-unreadable-array-destructuring": "allow",
    "unicorn/text-encoding-identifier-case": "allow",
    "unicorn/prefer-set-has": "allow",
    "typescript/prefer-for-of": "allow",
    "typescript/no-unsafe-function-type": "allow",
    "typescript/ban-types": "allow",
    "unicorn/prefer-type-error": "allow",
    "unicorn/prefer-math-min-max": "allow",
    "unicorn/prefer-date-now": "allow",
    "unicorn/prefer-math-trunc": "allow",
    "unicorn/prefer-includes": "allow",
    "unicorn/prefer-array-find": "allow",
    "unicorn/no-anonymous-default-export": "allow",
    "unicorn/no-abusive-eslint-disable": "allow",
    "typescript/prefer-ts-expect-error": "allow",
    "typescript/parameter-properties": "allow",
    "typescript/no-invalid-void-type": "allow",
    "typescript/ban-ts-comment": "allow",
    "unicorn/prefer-native-coercion-functions": "allow",
    "unicorn/prefer-logical-operator-over-ternary": "allow",
    "unicorn/prefer-event-target": "allow",
    "unicorn/prefer-blob-reading-methods": "allow",
    "unicorn/prefer-add-event-listener": "allow",
    "unicorn/no-useless-switch-case": "allow",
    "unicorn/no-new-buffer": "allow",
    "unicorn/no-invalid-fetch-options": "allow",
    "unicorn/no-await-expression-member": "allow",
    "unicorn/empty-brace-spaces": "allow",
    "no-bitwise": "allow",
    "no-param-reassign": "allow",
    "class-methods-use-this": "allow",
    "max-classes-per-file": "allow",
    "no-nested-ternary": "allow",
    "complexity": "allow"
  },
  "overrides": [
    {
      "files": [
        "**/*.{test,spec}.{ts,tsx,js,jsx}",
        "**/__tests__/**/*.{ts,tsx,js,jsx}"
      ],
      "plugins": ["jest"],
      "rules": {
        "jest/require-hook": "off",
        "jest/no-conditional-in-test": "off",
        "jest/no-hooks": "off",
        "promise/prefer-await-to-then": "off",
        "no-empty-function": "off",
        "jest/consistent-test-it": "error",
        "jest/expect-expect": "error",
        "jest/max-expects": ["error", { "max": 10 }],
        "jest/max-nested-describe": ["error", { "max": 10 }],
        "jest/no-alias-methods": "error",
        "jest/no-commented-out-tests": "error",
        "jest/no-conditional-expect": "error",
        "jest/no-confusing-set-timeout": "allow",
        "jest/no-deprecated-functions": "error",
        "jest/no-disabled-tests": "error",
        "jest/no-done-callback": "error",
        "jest/no-duplicate-hooks": "error",
        "jest/no-export": "error",
        "jest/no-focused-tests": "error",
        "jest/no-identical-title": "error",
        "jest/no-interpolation-in-snapshots": "error",
        "jest/no-jasmine-globals": "error",
        "jest/no-large-snapshots": "error",
        "jest/no-mocks-import": "error",
        "jest/no-restricted-jest-methods": "error",
        "jest/no-restricted-matchers": "error",
        "jest/no-standalone-expect": "error",
        "jest/no-test-prefixes": "error",
        "jest/no-test-return-statement": "error",
        "jest/no-untyped-mock-factory": "error",
        "jest/padding-around-test-blocks": "error",
        "jest/prefer-called-with": "error",
        "jest/prefer-comparison-matcher": "error",
        "jest/prefer-each": "allow",
        "jest/prefer-equality-matcher": "error",
        "jest/prefer-expect-resolves": "error",
        "jest/prefer-hooks-in-order": "error",
        "jest/prefer-hooks-on-top": "error",
        "jest/prefer-jest-mocked": "error",
        "jest/prefer-lowercase-title": "error",
        "jest/prefer-mock-promise-shorthand": "error",
        "jest/prefer-spy-on": "error",
        "jest/prefer-strict-equal": "error",
        "jest/prefer-to-be": "error",
        "jest/prefer-to-contain": "error",
        "jest/prefer-to-have-been-called": "error",
        "jest/prefer-to-have-been-called-times": "error",
        "jest/prefer-to-have-length": "error",
        "jest/prefer-todo": "error",
        "jest/require-to-throw-message": "error",
        "jest/require-top-level-describe": "error",
        "jest/valid-describe-callback": "error",
        "jest/valid-expect": "error",
        "jest/valid-title": "error"
      }
    }
  ]
}
