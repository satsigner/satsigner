    "buffer": "6.0.3",
    "cbor-js": "^0.1.0",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "electrum-client": "https://github.com/BlueWallet/rn-electrum-client#1bfe3cc4249d5440b816baac942b0cfa921eebf9",
    "events": "^1.0.0",
