{
  "name": "@satsigner/mobile",
  "version": "0.2.1",
  "private": true,
  "description": "Privacy-first Bitcoin signer with complete UTXO control",
  "main": "expo-router/entry",
  "react-native": {
    "net": "react-native-tcp-socket",
    "tls": "react-native-tcp-socket",
    "fs": "react-native-tcp-socket"
  },
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "postinstall": "rn-nodeify --install assert,buffer,events,process --hack",
    "sb:android": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:android",
    "sb:ios": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:ios",
    "start": "expo start",
    "storybook-generate": "sb-rn-get-stories",
    "test": "pnpm test:unit && pnpm test:int",
    "test:int": "jest ./tests/int",
    "test:unit": "jest ./tests/unit",
    "type-check": "tsc --noEmit",
    "types": "expo customize tsconfig.json"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@cashu/cashu-ts": "^3.0.0",
